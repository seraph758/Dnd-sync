<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="連線狀態"
        app:iconSpaceReserved="false">
        <Preference
            android:key="connectivity_state_key"
            android:title="雙端連通狀態"
            android:summary="正在檢測與手錶的連接..."
            android:icon="@android:drawable/stat_sys_data_bluetooth"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/sync_header"
        app:iconSpaceReserved="false">
        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="dnd_sync_key"
            android:title="同步勿擾模式"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/permission_header"
        app:iconSpaceReserved="false">
        <Preference
            android:key="dnd_permission_key"
            android:title="@string/dnd_permission_title"
            android:summary="勿擾訪問權限"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

</PreferenceScreen>
