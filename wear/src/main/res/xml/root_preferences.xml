<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory
        android:title="@string/sync_header"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="dnd_sync_key"
            android:title="同步勿扰模式"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:defaultValue="true"
            android:key="bedtime_key"
            android:title="就寝模式同步 (模拟点击)"
            android:summary="开启时将模拟点击手表的就寝模式"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/permission_header"
        app:iconSpaceReserved="false">

        <Preference
            android:key="dnd_permission_key"
            android:title="@string/dnd_permission_title"
            android:summary="勿扰访问权限"
            app:iconSpaceReserved="false" />

        <Preference
            android:key="acc_permission_key"
            android:title="辅助功能权限"
            android:summary="模拟点击需要此权限"
            app:iconSpaceReserved="false" />
            
    </PreferenceCategory>

    <PreferenceCategory
        android:title="@string/other_header"
        app:iconSpaceReserved="false">

        <SwitchPreferenceCompat
            android:defaultValue="false"
            android:key="vibrate_key"
            android:title="@string/vibrate_title"
            app:iconSpaceReserved="false" />
    </PreferenceCategory>

</PreferenceScreen>
